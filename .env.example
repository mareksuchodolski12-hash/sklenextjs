# PostgreSQL connection string used by Prisma migrations, generate, and runtime queries.
# Example for local Docker/hosted Postgres:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/verdant_atelier?schema=public"

# Auth.js secret used to sign/encrypt sessions/JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-secret"

# Optional provider: GitHub OAuth (recommended for production-ready social auth)
# GITHUB_ID=""
# GITHUB_SECRET=""

# Optional provider: Email magic link
# Example with MailHog/Mailpit for local development:
# EMAIL_SERVER="smtp://localhost:1025"
# EMAIL_FROM="Verdant Atelier <noreply@verdant-atelier.local>"
