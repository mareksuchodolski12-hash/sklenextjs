# Core runtime
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# App security
AUTH_SECRET=replace-with-long-random-value
ADMIN_EMAILS=owner@example.com

# Database
POSTGRES_DB=verdant_atelier
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verdant_atelier?schema=public

# OAuth / email (optional)
# GITHUB_ID=
# GITHUB_SECRET=
# EMAIL_SERVER=smtp://localhost:1025
# EMAIL_FROM="Verdant Atelier <noreply@verdant-atelier.local>"

# Stripe (optional for checkout integration)
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Container runtime
APP_PORT=3000
