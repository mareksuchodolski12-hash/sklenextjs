generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
  preorder
}

enum ProductDifficulty {
  easy
  moderate
  advanced
}

enum WateringLevel {
  low
  moderate
  high
}

enum SunlightRequirement {
  full_sun
  partial_shade
  full_shade
}

enum AttributeValueType {
  text
  number
  boolean
}

model Product {
  id                 String            @id @default(cuid())
  slug               String            @unique
  name               String
  shortDescription   String
  longDescription    String
  sku                String            @unique
  price              Decimal           @db.Decimal(10, 2)
  compareAtPrice     Decimal?          @db.Decimal(10, 2)
  featured           Boolean           @default(false)
  stockStatus        StockStatus       @default(in_stock)
  isActive           Boolean           @default(true)
  trackInventory     Boolean           @default(true)
  allowBackorder     Boolean           @default(false)
  quantityOnHand     Int               @default(0)
  quantityReserved   Int               @default(0)
  lowStockThreshold  Int               @default(5)
  minHardinessZone   Int?
  maxHardinessZone   Int?
  sunlight           SunlightRequirement
  watering           WateringLevel
  difficulty         ProductDifficulty
  floweringSeasons   String[]
  colorPalette       String[]
  styles             String[]
  effects            String[]
  tags               ProductTag[]
  favorites          FavoriteProduct[]
  categoryId         String
  category           Category          @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  collections        ProductCollection[]
  attributes         ProductAttribute[]
  relatedProducts    ProductRelation[] @relation("ProductRelationSource")
  relatedToProducts  ProductRelation[] @relation("ProductRelationTarget")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([categoryId])
  @@index([featured, stockStatus])
  @@index([isActive])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId, position])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Collection {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  subtitle    String?
  description String?
  isFeatured  Boolean             @default(false)
  products    ProductCollection[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ProductCollection {
  productId     String
  collectionId  String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId, sortOrder])
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  label     String
  products  ProductTag[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

model ProductAttribute {
  id           String             @id @default(cuid())
  productId    String
  product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  slug         String
  name         String
  valueType    AttributeValueType @default(text)
  valueText    String?
  valueNumber  Decimal?           @db.Decimal(10, 2)
  valueBoolean Boolean?
  unit         String?
  isFilterable Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([productId])
  @@index([slug])
}

model ProductRelation {
  sourceProductId String
  targetProductId String
  reason          String?
  createdAt       DateTime @default(now())
  sourceProduct   Product  @relation("ProductRelationSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct   Product  @relation("ProductRelationTarget", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@id([sourceProductId, targetProductId])
  @@index([targetProductId])
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  favorites      FavoriteProduct[]
  savedDiscovery SavedDiscovery[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model SavedDiscovery {
  id            String   @id @default(cuid())
  email         String?
  sessionId     String?
  userId        String?
  title         String?
  criteria      Json
  resultSlugs   String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([sessionId])
  @@index([userId])
}

model FavoriteProduct {
  userId    String
  productId String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([productId])
}


model StripeWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  status      String
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
}

model Order {
  id                  String      @id @default(cuid())
  stripeSessionId     String      @unique
  customerEmail       String?
  currency            String?
  amountSubtotalMinor Int?
  amountTotalMinor    Int?
  paymentStatus       String?
  metadata            Json?
  completedAt         DateTime?
  /// Set while a webhook execution holds the claim to send the confirmation email.
  confirmationEmailSendingAt DateTime?
  /// Set once confirmation delivery succeeds; prevents any future duplicate sends.
  confirmationEmailSentAt DateTime?
  orderItems          OrderItem[]
  payments            Payment[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  stripeLineItemId    String?
  description         String
  quantity            Int
  currency            String?
  unitAmountMinor     Int?
  amountSubtotalMinor Int?
  amountTotalMinor    Int?
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@index([orderId])
}

model Payment {
  id                    String   @id @default(cuid())
  orderId               String
  stripeSessionId       String   @unique
  stripePaymentIntentId String?
  customerEmail         String?
  currency              String?
  amountMinor           Int?
  status                String
  raw                   Json?
  order                 Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderId])
}
